       RowBox[{"and", " ", "\[Xi]"}]}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"coeffs", "=", 
       RowBox[{"{", 
