Cell[CellGroupData[{

Cell["Orthogonal vector definition", "Subsubsection",
 CellChangeTimes->{{3.9229895541093335`*^9, 
  3.9229895568122997`*^9}},ExpressionUUID->"afee474d-2ea5-473a-a548-\
ae9916be12df"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SO1", "[", "t_", "]"}], ":=", 
   RowBox[{"Cross", "[", 
    RowBox[{
     RowBox[{"ycapY", "[", "t", "]"}], ",", 
     RowBox[{"Sv", "[", "t", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"NormSO", "[", "t_", "]"}], ":=", 
   RowBox[{"Norm", "[", 
    RowBox[{"SO1", "[", "t", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SOu", "[", "t_", "]"}], ":=", 
  FractionBox[
   RowBox[{"SO1", "[", "t", "]"}], 
   RowBox[{"NormSO", "[", "t", "]"}]]}]}], "Input",
