     FractionBox[
      RowBox[{
       RowBox[{"NormJ", "[", "t", "]"}], "-", 
       RowBox[{
        RowBox[{"NormL", "[", "t", "]"}], 
        RowBox[{"cos\[Theta]L", "[", "t", "]"}]}]}], 
      RowBox[{"NormS", "[", "t", "]"}]], ",", "0", ",", 
     FractionBox[
      RowBox[{
       RowBox[{"NormL", "[", "t", "]"}], 
       RowBox[{"sin\[Theta]L", "[", "t", "]"}]}], 
      RowBox[{"NormS", "[", "t", "]"}]]}], "}"}]}], ";"}]], "Input",
