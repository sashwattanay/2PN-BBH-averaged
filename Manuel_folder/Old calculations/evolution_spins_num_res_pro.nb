Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dS1", "[", "t_", "]"}], " ", "=", "   ", 
   RowBox[{"Cross", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", 
        SuperscriptBox["d", "3"]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"4", "+", 
           FractionBox["3", "q"], "-", 
           RowBox[{
            FractionBox["3", 
             RowBox[{"(", 
              RowBox[{"q", "+", "1"}], ")"}]], "\[Lambda]"}]}], ")"}], 
         RowBox[{"J", "[", "t", "]"}]}], "-", 
        RowBox[{"S1", "[", "t", "]"}]}], ")"}]}], ",", 
     RowBox[{"S1", "[", "t", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dS2", "[", "t_", "]"}], " ", "=", "    ", 
   RowBox[{"Cross", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", 
        SuperscriptBox["d", "3"]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"4", "+", 
           RowBox[{"3", "q"}], "-", 
           RowBox[{
            FractionBox[
             RowBox[{"3", "q"}], 
             RowBox[{"(", 
              RowBox[{"q", "+", "1"}], ")"}]], "\[Lambda]"}]}], ")"}], 
         RowBox[{"J", "[", "t", "]"}]}], "-", 
        RowBox[{"S2", "[", "t", "]"}]}], ")"}]}], ",", 
     RowBox[{"S2", "[", "t", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dJ", "[", "t_", "]"}], "=", "     ", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "  ", ";"}]}], "Input",
 CellChangeTimes->{{3.9218688135855317`*^9, 3.9218688138859024`*^9}, {
  3.921868917936011*^9, 3.9218689585023403`*^9}, {3.921877578552071*^9, 
  3.9218775786918526`*^9}},
