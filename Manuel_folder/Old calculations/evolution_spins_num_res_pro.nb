        RowBox[{
         RowBox[{"S2", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"dS2", "[", "t", "]"}]}], " ", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"J", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"dJ", "[", "t", "]"}]}], ",", 
