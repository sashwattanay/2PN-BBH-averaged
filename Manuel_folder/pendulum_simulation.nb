Cell[TextData[{
 "We choose the point ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"\[Theta]", ",", 
             SubscriptBox[
              StyleBox["p", "TI"], "\[Theta]"]}], ")"}], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"0.83", ",", "2.13"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "(\\theta , p_\\theta)=(0.83, 2.13)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "12a431f0-e1be-4fdf-bc48-5079c86c6da1"],
 " in separatrix. Then, we choose two points slightly above and below \
separatrix regions by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Theta]", "\[LongEqual]", "\[PlusMinus]", "0.2"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\theta=\\pm 0.2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6395b4e-4390-466b-9cdf-bbc1fccddb2a"]
}], "Text",
 CellChangeTimes->{{3.932555417800541*^9, 3.9325555381826506`*^9}, {
  3.932555570520065*^9, 
  3.932555596623103*^9}},ExpressionUUID->"ce7b16c0-7dfd-4d0a-b434-\
fd2a356a756f"],

