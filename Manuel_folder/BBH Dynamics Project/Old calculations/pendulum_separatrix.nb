Cell["For rotation motion of the pendulum", "Text",
 CellChangeTimes->{{3.9192493463500347`*^9, 3.919249358771326*^9}, {
  3.91924993547616*^9, 
  3.9192499380527315`*^9}},ExpressionUUID->"08ace237-64aa-452b-8171-\
48cfaba7537c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Jr", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"8", 
       SqrtBox["\[Kappa]"]}], "\[Pi]"], 
     RowBox[{"(", 
      RowBox[{"EllipticE", "[", 
       SuperscriptBox["\[Kappa]", 
        RowBox[{"-", "1"}]], "]"}], ")"}]}], "/.", 
    RowBox[{"\[Kappa]", "->", 
     FractionBox["\[Epsilon]", "2"]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9192499540715475`*^9, 3.919249971225796*^9}, {
  3.9192510404806023`*^9, 3.9192510612970047`*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"48b47412-daf4-4440-bd5d-6a2b82f5771f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", 
   SqrtBox["2"], " ", 
   SqrtBox["\[Epsilon]"], " ", 
   RowBox[{"EllipticE", "[", 
    FractionBox["2", "\[Epsilon]"], "]"}]}], "\[Pi]"]], "Output",
 CellChangeTimes->{
  3.919249973059801*^9, {3.919251044359788*^9, 3.9192510625120726`*^9}, 
   3.9192513490538244`*^9},
 CellLabel->
  "Out[105]=",ExpressionUUID->"797476e8-82fc-426d-a689-3e2bdb6e50ca"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dJr", "=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{"Jr", ",", "\[Epsilon]"}], "]"}], "//", "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.9192499836118345`*^9, 3.919249986643841*^9}, {
  3.919251053632941*^9, 3.919251058701709*^9}, {3.9192513361681786`*^9, 
