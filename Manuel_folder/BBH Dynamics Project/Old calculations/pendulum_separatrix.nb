Notebook[{
Cell["For libration motion of the pendulum", "Text",
 CellChangeTimes->{{3.9192493463500347`*^9, 
  3.919249358771326*^9}},ExpressionUUID->"3b630a5f-2065-4cec-b7fd-\
98c400ae3fa6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Jl", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{
     FractionBox["8", "\[Pi]"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"EllipticE", "[", "\[Kappa]", "]"}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "\[Kappa]"}], ")"}], 
        RowBox[{"EllipticK", "[", "\[Kappa]", "]"}]}]}], ")"}]}], "/.", 
    RowBox[{"\[Kappa]", "->", 
     FractionBox["\[Epsilon]", "2"]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9192493614972215`*^9, 3.9192493816605787`*^9}, {
  3.919249417984846*^9, 3.919249488369969*^9}},
 CellLabel->
  "In[101]:=",ExpressionUUID->"36b093a7-5140-44c3-a7dd-995e7d13438a"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"8", " ", 
    RowBox[{"EllipticE", "[", 
     FractionBox["\[Epsilon]", "2"], "]"}]}], "+", 
   RowBox[{"4", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", "\[Epsilon]"}], ")"}], " ", 
    RowBox[{"EllipticK", "[", 
     FractionBox["\[Epsilon]", "2"], "]"}]}]}], "\[Pi]"]], "Output",
 CellChangeTimes->{{3.919249450504586*^9, 3.9192494889740095`*^9}, 
   3.9192513483011255`*^9},
 CellLabel->
  "Out[101]=",ExpressionUUID->"74cb46c4-3b01-410b-8428-4ffef65675ef"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dJl", "=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{"Jl", ",", "\[Epsilon]"}], "]"}], "//", "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.919249500409648*^9, 3.9192495239143305`*^9}, 
   3.919251330018539*^9},
 CellLabel->
  "In[102]:=",ExpressionUUID->"2f4e9b4e-929c-4e2d-b6d3-edbb678d0bfa"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   RowBox[{"EllipticK", "[", 
    FractionBox["\[Epsilon]", "2"], "]"}]}], "\[Pi]"]], "Output",
 CellChangeTimes->{3.9192495242402906`*^9, 3.91925134843606*^9},
 CellLabel->
  "Out[102]=",ExpressionUUID->"ccbdb73d-3409-4aee-a957-d2a8eaf1f509"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Jl", ",", "dJl"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Epsilon]", ",", "0", ",", "3"}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*SubscriptBox[\(J\), \(\[ScriptL]\)]\)\>\"", ",", 
      "\"\<\!\(\*FractionBox[SubscriptBox[\(dJ\), \(\[ScriptL]\)], \(d\
\[Epsilon]\)]\)\>\""}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Epsilon]\>\"", ",", "\"\<Lib. Motion\>\""}], "}"}]}]}], 
