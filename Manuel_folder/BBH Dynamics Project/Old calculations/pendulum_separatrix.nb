Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SqrtBox["2"], " ", 
   RowBox[{"EllipticK", "[", 
    FractionBox["2", "\[Epsilon]"], "]"}]}], 
  RowBox[{"\[Pi]", " ", 
   SqrtBox["\[Epsilon]"]}]]], "Output",
 CellChangeTimes->{
  3.919249987318804*^9, {3.9192510550786314`*^9, 3.919251064487833*^9}, 
