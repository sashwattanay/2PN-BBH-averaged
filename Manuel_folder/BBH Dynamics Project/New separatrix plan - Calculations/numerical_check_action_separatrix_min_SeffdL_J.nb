 RowBox[{
  RowBox[{"roots", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["f", "k"], "->", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["a2", 
         RowBox[{"3", "a3"}]]}], "+", 
       RowBox[{"2", 
        SqrtBox[
         FractionBox[
          RowBox[{"-", "p"}], "3"]], 
        RowBox[{"Cos", "[", 
