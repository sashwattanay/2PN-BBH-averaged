     SuperscriptBox["a3", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"2", 
      SuperscriptBox["a2", "3"]}], "-", 
