Cell[BoxData[{
 RowBox[{
  RowBox[{"cubic", " ", "=", "    ", 
   RowBox[{"Expand", "[", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["L", "2"], " ", 
      SuperscriptBox["S1", "2"], " ", 
      SuperscriptBox["S2", "2"]}], "-", " ", 
     RowBox[{"2", " ", "\[Sigma]1", " ", "\[Sigma]2", " ", 
      RowBox[{"(", 
       RowBox[{"\[Sigma]1", "-", "\[Sigma]2"}], ")"}], "f", 
      RowBox[{"(", 
       RowBox[{"f", "-", "\[CapitalDelta]1"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"f", "-", "\[CapitalDelta]2"}], ")"}]}], "-", 
     RowBox[{
      SuperscriptBox["L", "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Sigma]1", "-", "\[Sigma]2"}], ")"}], "2"], 
      SuperscriptBox["f", "2"]}], "-", 
     RowBox[{
      SuperscriptBox["S2", "2"], 
      SuperscriptBox["\[Sigma]2", "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"f", "-", "\[CapitalDelta]1"}], ")"}], "2"]}], "-", 
     RowBox[{
      SuperscriptBox["S1", "2"], 
      SuperscriptBox["\[Sigma]1", "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"f", "-", "\[CapitalDelta]2"}], ")"}], "2"]}]}], "  ", 
    "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"The", " ", "cubic", " ", "polynomial", " ", "of", " ", 
     RowBox[{"Eq", ".", " ", "3.1"}], " ", "of", " ", "Cho"}], "-", "Lee"}], 
   "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a3", "=", 
   RowBox[{"Coefficient", "[", 
    RowBox[{"cubic", ",", 
     SuperscriptBox["f", "3"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a2", "=", 
   RowBox[{"Coefficient", "[", 
    RowBox[{"cubic", ",", 
     SuperscriptBox["f", "2"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a1", "=", 
   RowBox[{"Coefficient", "[", 
    RowBox[{"cubic", ",", "f"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a0", "=", 
   RowBox[{"Expand", "[", 
    RowBox[{"cubic", "-", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"a3", " ", 
        SuperscriptBox["f", "3"]}], "+", 
       RowBox[{"a2", " ", 
        SuperscriptBox["f", "2"]}], "+", 
       RowBox[{"a1", " ", "f"}]}], ")"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"3", " ", "a1", " ", "a3"}], "-", 
     SuperscriptBox["a2", "2"]}], 
