Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"S1dL", "=", 
  RowBox[{"S1", " ", "L", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[Theta]1", "]"}], " ", 
      RowBox[{"Cos", "[", "0", "]"}]}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]1", "]"}], " ", 
