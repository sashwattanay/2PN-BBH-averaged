  RowBox[{"{", 
   RowBox[{"Linit", ",", " ", "S1init", ",", " ", "S2init"}], "}"}], "=", 
  "VectorVector"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S0", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       FractionBox["m2", "m1"]}], ")"}], 
     RowBox[{"S1", "[", "t", "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       FractionBox["m1", "m2"]}], ")"}], 
     RowBox[{"S2", "[", "t", "]"}]}]}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", " ", "=", " ", 
   RowBox[{
    RowBox[{"S1", "[", "t", "]"}], "+", 
    RowBox[{"S2", "[", "t", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]", " ", "=", " ", 
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         FractionBox["m2", "m1"]}], ")"}], 
       RowBox[{
        RowBox[{"L", "[", "t", "]"}], ".", 
        RowBox[{"S1", "[", "t", "]"}]}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
