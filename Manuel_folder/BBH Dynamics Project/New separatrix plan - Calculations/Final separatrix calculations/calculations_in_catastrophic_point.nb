      "inputArray"}], ";", "\[IndentingNewLine]", 
     RowBox[{"L", "=", 
      RowBox[{"7", "/", "10"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"S1", "=", 
      RowBox[{"3", "/", "10"}]}], ";", "\[IndentingNewLine]", 
