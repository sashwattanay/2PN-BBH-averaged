Cell[CellGroupData[{

Cell["Spherical to cartesian", "Subsection",
 CellChangeTimes->{{3.946483538306775*^9, 
  3.946483542063801*^9}},ExpressionUUID->"79e6e391-e32d-41dc-a816-\
e6c6120c8b30"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"CartesianVector", "[", 
    RowBox[{"r_", ",", "\[Theta]_", ",", "\[Phi]_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RotateVectorAroundAxis", "[", 
    RowBox[{"L_", ",", "S_", ",", "phi_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "SUnit", ",", "LParallel", ",", "LPerpendicular", ",", "RotationMatrix",
        ",", "LFinal"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SUnit", "=", 
       RowBox[{"Normalize", "[", "S", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"LParallel", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Dot", "[", 
          RowBox[{"L", ",", "SUnit"}], "]"}], ")"}], " ", "SUnit"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"LPerpendicular", "=", 
       RowBox[{"L", "-", "LParallel"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"RotationMatrix", "=", 
       RowBox[{"RotationTransform", "[", 
        RowBox[{"phi", ",", "SUnit"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"LFinal", "=", 
       RowBox[{"LParallel", "+", 
        RowBox[{"RotationMatrix", "[", "LPerpendicular", "]"}]}]}], ";", 
      "\[IndentingNewLine]", "LFinal"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9464847261919155`*^9, 3.94648472761125*^9}},
