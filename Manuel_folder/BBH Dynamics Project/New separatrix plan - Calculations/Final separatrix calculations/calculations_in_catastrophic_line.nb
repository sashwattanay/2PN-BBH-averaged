Cell[BoxData[{
 RowBox[{
  RowBox[{"d", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m1", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"m2", " ", "=", " ", 
    RowBox[{"1", "/", "2"}]}], " ", ";"}], "  "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{"m1", "+", "m2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]", " ", "=", "  ", 
   FractionBox[
    RowBox[{"m1", " ", "m2"}], "M"]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", " ", "=", " ", 
   FractionBox["m1", "m2"]}], " ", ";"}]}], "Input",
 CellChangeTimes->{{3.946480190420491*^9, 3.9464801906973257`*^9}, {
  3.9464829596556406`*^9, 3.9464829741896906`*^9}},
 CellLabel->
