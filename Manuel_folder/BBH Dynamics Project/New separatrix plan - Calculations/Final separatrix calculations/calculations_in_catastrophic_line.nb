Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dS1", "[", "t_", "]"}], " ", "=", "   ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", " ", 
      SuperscriptBox["d", "3"]}]], " ", 
    RowBox[{"Cross", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", " ", "+", " ", 
          RowBox[{"3", " ", 
           FractionBox["m2", "m1"]}], " ", "-", " ", 
          RowBox[{"3", " ", 
           FractionBox["\[Mu]", "m1"], 
           RowBox[{"(", " ", 
            FractionBox[
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m2", "m1"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S1", "[", "t", "]"}]}]}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m1", "m2"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S2", "[", "t", "]"}], " "}]}]}], 
             SuperscriptBox[
              RowBox[{"Norm", "[", 
               RowBox[{"L", "[", "t", "]"}], "]"}], "2"]], ")"}]}]}], ")"}], 
        RowBox[{"L", "[", "t", "]"}]}], "+", 
       RowBox[{"S2", "[", "t", "]"}]}], ",", " ", 
      RowBox[{"S1", "[", "t", "]"}]}], "]"}]}]}], " ", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dS2", "[", "t_", "]"}], " ", "=", "    ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", " ", 
      SuperscriptBox["d", "3"]}]], " ", 
    RowBox[{"Cross", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", " ", "+", " ", 
          RowBox[{"3", " ", 
           FractionBox["m1", "m2"]}], " ", "-", " ", 
          RowBox[{"3", " ", 
           FractionBox["\[Mu]", "m2"], " ", 
           RowBox[{"(", " ", 
            FractionBox[
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m2", "m1"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S1", "[", "t", "]"}]}]}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m1", "m2"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S2", "[", "t", "]"}], " "}]}]}], 
             SuperscriptBox[
              RowBox[{"Norm", "[", 
               RowBox[{"L", "[", "t", "]"}], "]"}], "2"]], ")"}]}]}], ")"}], 
        RowBox[{"L", "[", "t", "]"}]}], "+", 
       RowBox[{"S1", "[", "t", "]"}]}], ",", " ", 
      RowBox[{"S2", "[", "t", "]"}]}], "]"}]}]}], " ", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dL", "[", "t_", "]"}], "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", " ", 
      SuperscriptBox["d", "3"]}]], " ", 
    RowBox[{"Cross", "[", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"S1", "[", "t", "]"}], "+", 
         RowBox[{"S2", "[", "t", "]"}]}], ")"}], " ", "+", 
       RowBox[{"3", " ", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{
           FractionBox["\[Mu]", "M"], 
           RowBox[{"(", " ", 
            FractionBox[
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m2", "m1"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S1", "[", "t", "]"}]}]}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 FractionBox["m1", "m2"]}], ")"}], 
               RowBox[{
                RowBox[{"L", "[", "t", "]"}], ".", 
                RowBox[{"S2", "[", "t", "]"}], " "}]}]}], 
             SuperscriptBox[
              RowBox[{"Norm", "[", 
               RowBox[{"L", "[", "t", "]"}], "]"}], "2"]], ")"}]}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", 
             FractionBox["m2", "m1"]}], ")"}], 
           RowBox[{"S1", "[", "t", "]"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", 
             FractionBox["m1", "m2"]}], ")"}], 
           RowBox[{"S2", "[", "t", "]"}]}]}], ")"}]}]}], ",", " ", 
      RowBox[{"L", "[", "t", "]"}]}], "]"}]}]}], " ", ";"}]}], "Input",
 CellChangeTimes->{
