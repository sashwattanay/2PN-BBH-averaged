      RowBox[{"(", 
       RowBox[{"f", "-", "\[CapitalDelta]2"}], ")"}]}], "-", 
     RowBox[{
      SuperscriptBox["L", "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Sigma]1", "-", "\[Sigma]2"}], ")"}], "2"], 
      SuperscriptBox["f", "2"]}], "-", 
     RowBox[{
      SuperscriptBox["S2", "2"], 
      SuperscriptBox["\[Sigma]2", "2"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"f", "-", "\[CapitalDelta]1"}], ")"}], "2"]}], "-", 
     RowBox[{
      SuperscriptBox["S1", "2"], 
      SuperscriptBox["\[Sigma]1", "2"], 
