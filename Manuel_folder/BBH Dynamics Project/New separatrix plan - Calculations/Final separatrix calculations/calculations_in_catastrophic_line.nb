     RowBox[{"{", 
      RowBox[{"S1", ",", "S2", ",", "L"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}], ";"}]}], "Input",
