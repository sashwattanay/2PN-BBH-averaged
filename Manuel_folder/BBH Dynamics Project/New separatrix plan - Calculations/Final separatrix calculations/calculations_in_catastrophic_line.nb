            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"L", "+", "S"}], ")"}], "2"]}]], " ", 
          SqrtBox[
           RowBox[{
            SuperscriptBox["S", "2"], "-", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"S1", "-", "S2"}], ")"}], "2"]}]], " ", 
          SqrtBox[
           RowBox[{
            RowBox[{"-", 
