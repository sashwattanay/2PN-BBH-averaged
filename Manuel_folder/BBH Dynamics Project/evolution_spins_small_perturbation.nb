 CellChangeTimes->{{3.92298976964902*^9, 
  3.922989771195784*^9}},ExpressionUUID->"56d79ac7-2269-497c-8019-\
f72b6599751a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"cos\[Phi]1", "[", "t_", "]"}], ":=", 
   FractionBox[
    RowBox[{"Dot", "[", 
     RowBox[{
      RowBox[{"S1u", "[", "t", "]"}], ",", 
      RowBox[{"SOu", "[", "t", "]"}]}], "]"}], 
    RowBox[{"Norm", "[", 
     RowBox[{"Cross", "[", 
      RowBox[{
       RowBox[{"S1u", "[", "t", "]"}], ",", 
       RowBox[{"Su", "[", "t", "]"}]}], "]"}], "]"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.9229897945179954`*^9, 3.922989824653908*^9}, {
  3.9268134822672205`*^9, 3.9268134903628616`*^9}},
