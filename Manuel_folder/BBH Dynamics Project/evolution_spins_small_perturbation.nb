Cell[CellGroupData[{

Cell["Effective potential \[Xi] (constant of motion) evolution", \
"Subsubsection",
 CellChangeTimes->{{3.926810245194439*^9, 3.9268102610406427`*^9}, 
   3.931530390336138*^9},ExpressionUUID->"48ba7001-ea94-4f4f-aa7a-\
bd9935b870ad"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Xi]01", "[", "t_", "]"}], ":=", 
  RowBox[{"Dot", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "q"}], ")"}], 
       RowBox[{"S1v", "[", "t", "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["q", 
          RowBox[{"-", "1"}]]}], ")"}], 
       RowBox[{"S2v", "[", "t", "]"}]}]}], ")"}], ",", 
    FractionBox[
     RowBox[{"Lv", "[", "t", "]"}], 
     RowBox[{"NormL", "[", "t", "]"}]]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Xi]02", "[", "t_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"4", " ", "q", " ", 
     RowBox[{"NormL", "[", "t", "]"}], " ", 
     SuperscriptBox[
      RowBox[{"NormS", "[", "t", "]"}], "2"]}]], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        SuperscriptBox["q", "2"]}], ")"}], " ", 
      RowBox[{"cos\[Phi]1", "[", "t", "]"}], " ", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"NormJ", "[", "t", "]"}], "2"], "-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"NormL", "[", "t", "]"}], "-", 
           RowBox[{"NormS", "[", "t", "]"}]}], ")"}], "2"]}]], " ", 
      SqrtBox[
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"NormJ", "[", "t", "]"}], "2"]}], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"NormL", "[", "t", "]"}], "+", 
           RowBox[{"NormS", "[", "t", "]"}]}], ")"}], "2"]}]], " ", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"NormS", "[", "t", "]"}], "2"], "-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"NormS1", "[", "t", "]"}], "-", 
           RowBox[{"NormS2", "[", "t", "]"}]}], ")"}], "2"]}]], " ", 
      SqrtBox[
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"NormS", "[", "t", "]"}], "2"]}], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"NormS1", "[", "t", "]"}], "+", 
           RowBox[{"NormS2", "[", "t", "]"}]}], ")"}], "2"]}]]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"NormJ", "[", "t", "]"}], "2"], "-", 
        SuperscriptBox[
         RowBox[{"NormL", "[", "t", "]"}], "2"], "-", 
        SuperscriptBox[
         RowBox[{"NormS", "[", "t", "]"}], "2"]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", "q"}], ")"}], "2"], " ", 
         SuperscriptBox[
          RowBox[{"NormS", "[", "t", "]"}], "2"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["q", "2"]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"NormS1", "[", "t", "]"}], "2"], "-", 
           SuperscriptBox[
            RowBox[{"NormS2", "[", "t", "]"}], "2"]}], ")"}]}]}], ")"}]}]}], 
    ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.9266995322854967`*^9, 3.926699576896469*^9}, {
