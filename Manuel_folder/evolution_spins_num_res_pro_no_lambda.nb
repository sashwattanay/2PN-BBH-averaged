Cell[CellGroupData[{

Cell["Region Plot for \[Xi] vs S", "Subsubsection",
 CellChangeTimes->{{3.9325607049694004`*^9, 
  3.9325607174663167`*^9}},ExpressionUUID->"2dee670c-7358-491a-8f4a-\
6da2160b1876"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Cont\[Xi]S", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"4", " ", "L", "  ", "q", " ", 
        SuperscriptBox["S", "2"]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["J", "2"], "-", 
           SuperscriptBox["L", "2"], "-", 
           SuperscriptBox["S", "2"]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "+", "q"}], ")"}], "2"], " ", 
            SuperscriptBox["S", "2"]}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["q", "2"]}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["S1", "2"], "-", 
              SuperscriptBox["S2", "2"]}], ")"}]}]}], ")"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["q", "2"]}], ")"}], " ", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["J", "2"], "-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"L", "-", "S"}], ")"}], "2"]}]], " ", 
         SqrtBox[
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["J", "2"]}], "+", 
           SuperscriptBox[
            RowBox[{"(", 
