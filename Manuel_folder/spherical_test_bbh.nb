Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DotProductSpherical", "[", 
    RowBox[{
    "r1_", ",", "\[Theta]1_", ",", "\[Phi]1_", ",", "r2_", ",", "\[Theta]2_", 
     ",", "\[Phi]2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "cosGamma", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"cosGamma", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Theta]1", "]"}], " ", 
         RowBox[{"Cos", "[", "\[Theta]2", "]"}]}], "+", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Theta]1", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]2", "]"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"\[Phi]1", "-", "\[Phi]2"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"r1", " ", "r2", " ", "cosGamma"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"CartesianVector", "[", 
    RowBox[{"r_", ",", "\[Theta]_", ",", "\[Phi]_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9425661475279055`*^9, 3.9425662332561207`*^9}, {
