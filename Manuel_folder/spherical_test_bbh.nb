Cell["Verify with Gram matrix", "Text",
 CellChangeTimes->{{3.9425669203881884`*^9, 
  3.9425669294822426`*^9}},ExpressionUUID->"46f17aae-a9ad-44de-8cef-\
90762c1d9f7d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GramMatrix", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"Dot", "[", 
        RowBox[{"Lv", ",", "Lv"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"Lv", ",", "S1v"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"Lv", ",", "S2v"}], "]"}]},
      {
       RowBox[{"Dot", "[", 
        RowBox[{"Lv", ",", "S1v"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"S1v", ",", "S1v"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"S1v", ",", "S2v"}], "]"}]},
      {
       RowBox[{"Dot", "[", 
        RowBox[{"Lv", ",", "S2v"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"S1v", ",", "S2v"}], "]"}], 
       RowBox[{"Dot", "[", 
        RowBox[{"S2v", ",", "S2v"}], "]"}]}
     }], "\[NoBreak]", ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Det", "[", "GramMatrix", "]"}], "\[IndentingNewLine]", 
 RowBox[{"0", "<=", 
  RowBox[{"Det", "[", "GramMatrix", "]"}], "<=", 
  RowBox[{"3", 
   RowBox[{"Dot", "[", 
    RowBox[{"Lv", ",", "Lv"}], "]"}], 
   RowBox[{"Dot", "[", 
    RowBox[{"S1v", ",", "S1v"}], "]"}], 
   RowBox[{"Dot", "[", 
    RowBox[{"S2v", ",", "S2v"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.94256699033051*^9, 3.9425670991623783`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"5908ea64-e56a-4e87-902a-99ce78d0d9d1"],

