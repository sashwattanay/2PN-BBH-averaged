Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"I3", "[", "x_", "]"}], ":=", 
    FractionBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "-", 
       RowBox[{"x", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "-", 
       RowBox[{"x", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ")"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DI3", "[", 
   RowBox[{"J_", ",", "L_", ",", "\[Xi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "ratio", ",", "derivative"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"x", "=", 
      RowBox[{"SolveAndSortRoots", "[", 
       RowBox[{"J", ",", "L", ",", "\[Xi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ratio", "=", 
      RowBox[{"I3", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"derivative", "=", 
      RowBox[{"D", "[", 
       RowBox[{"ratio", ",", "\[Xi]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "derivative"}]}], "]"}]}]}], "Input",
