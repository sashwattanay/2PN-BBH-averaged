Cell[BoxData[
 RowBox[{
  RowBox[{"SolveAndSortRoots", "[", 
   RowBox[{"J_", ",", "L_", ",", "\[Xi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "roots", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"roots", "=", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "3"], "+", 
          RowBox[{"J", " ", 
           SuperscriptBox["x", "2"]}], "+", 
          RowBox[{"L", " ", "x"}], "+", "\[Xi]"}], "==", "0"}], ",", "x"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"roots", "=", 
      RowBox[{
       RowBox[{"x", "/.", " ", "roots"}], "//", "Simplify"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Sort", "[", "roots", "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.936834372868919*^9, 3.9368344427337303`*^9}, {
   3.936835040521699*^9, 3.936835143641884*^9}, 3.9368352044757767`*^9},
