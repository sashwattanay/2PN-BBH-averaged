Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"S1dL", "=", 
  RowBox[{"S1", " ", "L", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[Theta]1", "]"}], " ", 
      RowBox[{"Cos", "[", "0", "]"}]}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]1", "]"}], " ", 
      RowBox[{"Sin", "[", "0", "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Phi]1", "-", "0"}], "]"}]}]}], 
    ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"S2dL", "=", 
  RowBox[{"S2", " ", "L", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[Theta]2", "]"}], " ", 
      RowBox[{"Cos", "[", "0", "]"}]}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]2", "]"}], " ", 
      RowBox[{"Sin", "[", "0", "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Phi]2", "-", "0"}], "]"}]}]}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.944519870480817*^9, 3.9445199417144575`*^9}, {
  3.9445207067547145`*^9, 3.9445207105014863`*^9}},
