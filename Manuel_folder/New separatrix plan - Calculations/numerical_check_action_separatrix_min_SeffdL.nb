 RowBox[{"(*", 
  RowBox[{"SeffdL", "=", 
   RowBox[{
    RowBox[{"\[Sigma]1", " ", "S1dL"}], "+", 
    RowBox[{"\[Sigma]2", " ", "S2dL"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.944519605313837*^9, 3.944519614675023*^9}, {
