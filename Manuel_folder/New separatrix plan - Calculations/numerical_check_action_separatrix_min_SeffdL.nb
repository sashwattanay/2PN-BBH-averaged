    RowBox[{"3", 
     SuperscriptBox["a3", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"2", 
      SuperscriptBox["a2", "3"]}], "-", 
     RowBox[{"9", "a1", " ", "a2", " ", "a3"}], "+", 
     RowBox[{"27", "a0", " ", 
      SuperscriptBox["a3", "2"]}]}], 
    RowBox[{"27", 
     SuperscriptBox["a3", "3"]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"roots", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["f", "k"], "->", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["a2", 
         RowBox[{"3", "a3"}]]}], "+", 
       RowBox[{"2", 
        SqrtBox[
         FractionBox[
          RowBox[{"-", "p"}], "3"]], 
        RowBox[{"Cos", "[", 
         RowBox[{
          RowBox[{
           FractionBox["1", "3"], 
           RowBox[{"ArcCos", "[", 
            RowBox[{
             FractionBox[
              RowBox[{"3", "q"}], 
