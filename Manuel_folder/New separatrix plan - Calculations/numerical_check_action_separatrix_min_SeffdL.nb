  3.9445195886207094`*^9}},ExpressionUUID->"864db1ae-a91a-4fa8-8f5a-\
8c89d8c65383"],

Cell[TextData[{
 "Assumming ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["L", "TI"], "\[RightVector]"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{L}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "15934b76-9ae8-413c-97c2-8143b41f53dc"],
 " along the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["z", "TI"], TraditionalForm], "errors" -> {}, "input" -> "z", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9231c277-05fa-4278-bb01-340b8e730ce4"],
 " axis, thus ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", 
          StyleBox["L", "TI"]], "\[LongEqual]", 
         SubscriptBox["\[Phi]", 
          StyleBox["L", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\theta_L=\\phi_L=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "20219299-4506-4955-8592-2840fbf3327d"]
}], "Text",
