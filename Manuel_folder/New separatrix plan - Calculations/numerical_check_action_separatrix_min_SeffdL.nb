Cell[TextData[{
 "Spherical ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "5"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "657cdafb-15a1-4226-8ac8-78fe89e3b730"]
}], "Subsection",
