Cell[BoxData[{
 RowBox[{
  RowBox[{"cubic", " ", "=", "    ", 
   RowBox[{"Expand", "[", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["L", "2"], " ", 
