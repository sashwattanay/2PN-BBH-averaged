Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ComputeAngles", "[", "vectors_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "L", ",", "S1", ",", "S2", ",", "anglesRadians", ",", "anglesDegrees"}],
       "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Extract", " ", "the", " ", "vectors", " ", "from", " ", "the", " ", 
       "input", " ", "list"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"L", ",", "S1", ",", "S2"}], "}"}], "=", "vectors"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Compute", " ", "mutual", " ", "angles", " ", "in", " ", "radians"}], 
       "*)"}], 
      RowBox[{"anglesRadians", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ArcCos", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", ".", "S1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Norm", "[", "L", "]"}], " ", 
             RowBox[{"Norm", "[", "S1", "]"}]}], ")"}]}], "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Angle", " ", "between", " ", "L", " ", "and", " ", "S1"}], 
          "*)"}], 
         RowBox[{"ArcCos", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", ".", "S2"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Norm", "[", "L", "]"}], " ", 
             RowBox[{"Norm", "[", "S2", "]"}]}], ")"}]}], "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Angle", " ", "between", " ", "L", " ", "and", " ", "S2"}], 
          "*)"}], 
         RowBox[{"ArcCos", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"S1", ".", "S2"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Norm", "[", "S1", "]"}], " ", 
             RowBox[{"Norm", "[", "S2", "]"}]}], ")"}]}], "]"}]}], " ", 
        RowBox[{"(*", 
         RowBox[{"Angle", " ", "between", " ", "S1", " ", "and", " ", "S2"}], 
         "*)"}], "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Convert", " ", "angles", " ", "to", " ", "degrees"}], "*)"}], 
      
      RowBox[{"anglesDegrees", "=", 
       RowBox[{"N", "[", 
        RowBox[{"anglesRadians", "*", 
         RowBox[{"180", "/", "Pi"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Return", " ", "angles", " ", "in", " ", "both", " ", "radians", " ", 
