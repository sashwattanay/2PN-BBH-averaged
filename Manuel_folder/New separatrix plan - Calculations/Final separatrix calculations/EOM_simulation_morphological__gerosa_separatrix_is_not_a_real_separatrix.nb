Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"VisualizeVectors3D", "[", "vectors_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"arrows", ",", "colors"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Define", " ", "colors", " ", "for", " ", "each", " ", "vector"}], 
      "*)"}], 
     RowBox[{
      RowBox[{"colors", "=", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Green", ",", "Blue"}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Create", " ", "Arrow", " ", "objects", " ", "for", " ", "each", " ", 
        "vector", " ", "with", " ", "corresponding", " ", "color"}], "*)"}], 
      RowBox[{"arrows", "=", 
       RowBox[{"MapThread", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"#1", ",", 
            RowBox[{"Arrow", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", "#2"}], "}"}], 
             "]"}]}], "}"}], "&"}], ",", 
         RowBox[{"{", 
          RowBox[{"colors", ",", "vectors"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Visualize", " ", "the", " ", "arrows", " ", "in", " ", "3", "D", " ", 
        "space"}], "*)"}], 
      RowBox[{"Graphics3D", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"arrows", ",", 
          RowBox[{"(*", 
           RowBox[{
           "Render", " ", "arrows", " ", "in", " ", "specified", " ", 
            "colors"}], "*)"}], 
          RowBox[{"{", 
           RowBox[{"Black", ",", 
            RowBox[{"PointSize", "[", "Large", "]"}], ",", 
            RowBox[{"Point", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0", ",", "0"}], "}"}], "]"}]}], "}"}]}], " ", 
         RowBox[{"(*", 
          RowBox[{"Mark", " ", "the", " ", "origin"}], "*)"}], "}"}], ",", 
        RowBox[{"Axes", "->", "True"}], ",", 
        RowBox[{"(*", 
         RowBox[{"Show", " ", "axes", " ", "for", " ", "reference"}], "*)"}], 
        
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}], 
        ",", 
        RowBox[{"(*", 
         RowBox[{"Label", " ", "the", " ", "axes"}], "*)"}], 
        RowBox[{"Boxed", "->", "True"}], ",", 
        RowBox[{"(*", 
         RowBox[{
         "Keep", " ", "the", " ", "bounding", " ", "box", " ", "visible"}], 
         "*)"}], 
        RowBox[{"ViewPoint", "->", 
         RowBox[{"{", 
          RowBox[{"2", ",", "2", ",", "2"}], "}"}]}]}], " ", 
       RowBox[{"(*", 
        RowBox[{"Adjust", " ", "view", " ", "angle"}], "*)"}], "]"}]}]}], 
    "]"}]}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Example", " ", "usage"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"VisualizeVectors3D", "[", "VectorVector", "]"}]}], "Input",
 CellChangeTimes->{{3.946131617299144*^9, 3.946131630036442*^9}, {
  3.946133742882832*^9, 3.94613374370652*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"8a865a5b-eb66-4253-ba20-3a714dbc3a8e"],

