63dafa05492f"],

Cell[TextData[{
 "SURPRISING FINDINGS:\n1. dJ blows up everywhere on the separatrix. At the \
critical point (CP), it blows up in a subtle manner: approach the CP from the \
separatrix side to see the blow up.\n2. If C(x,y) has dC = 0, then  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["dV", "c"], "/", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"dx", " ", "dy"}], ")"}], 
      RowBox[{"1", "/", "2"}]]}], " ", "->", "0"}], TraditionalForm]],
  ExpressionUUID->"9fe4f809-3c16-4596-9f14-1f0bbaafd94c"],
 ", where dx=dy and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["dV", "c"], TraditionalForm]],ExpressionUUID->
  "52575c38-3f44-4116-aff7-c00f6979694f"],
 " = differential volume in C space "
}], "Text",
 CellChangeTimes->{{3.9336844636766663`*^9, 3.933684826670917*^9}, {
  3.9339515174174967`*^9, 3.933951628216138*^9}, {3.933970951373954*^9, 
  3.933970953008657*^9}, {3.933971012615307*^9, 
  3.9339711024357567`*^9}},ExpressionUUID->"87dd62c0-c4c2-4e52-965e-\
3b612fb4888f"]
},
