Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PB", "[", 
    RowBox[{"a_", ",", "b_Plus"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"PB", "[", 
