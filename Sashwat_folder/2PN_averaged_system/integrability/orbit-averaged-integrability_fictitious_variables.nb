     RowBox[{"PB", "[", 
      RowBox[{"a", ",", "b"}], "]"}], "c"}], "+", 
    RowBox[{"b", " ", 
     RowBox[{"PB", "[", 
      RowBox[{"a", ",", "c"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
