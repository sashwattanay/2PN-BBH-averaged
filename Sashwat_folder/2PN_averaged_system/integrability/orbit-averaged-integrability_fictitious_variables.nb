         RowBox[{"PB", "[", 
          RowBox[{"a", ",", "#1"}], "]"}], " ", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Derivative", "@@", "#2"}], ")"}], "@", "func"}], "@@", 
          RowBox[{"{", "args", "}"}]}]}], ")"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "args", "}"}], ",", 
        RowBox[{"IdentityMatrix", "@", 
