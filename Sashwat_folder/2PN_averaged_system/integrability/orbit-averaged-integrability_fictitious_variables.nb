     "C8", ",", "C9", ",", "C10", ",", "DD"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefManifold", "[", 
   RowBox[{"M", ",", "3", ",", "    ", 
    RowBox[{"Complement", "[", 
     RowBox[{
      RowBox[{"IndexRange", "[", 
       RowBox[{"a", ",", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "r", ",", "p"}], "}"}]}], "]"}]}], "  ", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"DefMetric", "[", 
  RowBox[{"1", ",", 
   RowBox[{"\[Delta]", "[", 
    RowBox[{
     RowBox[{"-", "a"}], ",", 
     RowBox[{"-", "b"}]}], "]"}], ",", "PD", ",", 
   RowBox[{"FlatMetric", "\[Rule]", "True"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "epsilon\[Delta]", "]"}], "^=", 
   "\"\<\[Epsilon]\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"DefTensor", "[", 
      RowBox[{
       RowBox[{"#", "[", "a", "]"}], ",", "M"}], "]"}], "&"}], "/@", 
    RowBox[{"{", 
     RowBox[{
     "R", ",", "P", " ", ",", "L", ",", "J", ",", "n", ",", "R1", ",", "R2", 
      ",", "P1", ",", "P2"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DefLabeledSpatialVector", "[", 
    RowBox[{"v_", ",", 
     RowBox[{"M_", "?", "ManifoldQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"nums", ",", 
       RowBox[{"b", "=", 
        RowBox[{"DummyIn", "[", 
         RowBox[{"TangentBundleOfManifold", "[", "M", "]"}], "]"}]}], ",", 
       RowBox[{"d", "=", 
        RowBox[{"DummyIn", "[", 
         RowBox[{"TangentBundleOfManifold", "[", "M", "]"}], "]"}]}]}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"xTensorQ", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", "True"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Dagger", "[", 
        RowBox[{"v", "[", "l___", "]"}], "]"}], "^:=", 
       RowBox[{"v", "[", "l", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DefInfo", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"{", 
        RowBox[{"\"\<tensor\>\"", ",", "\"\<\>\""}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DependenciesOfTensor", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"{", "M", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"HostsOf", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"{", 
        RowBox[{"M", ",", 
         RowBox[{"TangentBundleOfManifold", "[", "M", "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"PrintAs", "[", 
        RowBox[{"v", "[", "l__", "]"}], "]"}], "^:=", 
       RowBox[{"SubscriptBox", "[", 
        RowBox[{
         RowBox[{"ToString", "[", "v", "]"}], ",", 
         RowBox[{"StringJoin", "@@", 
          RowBox[{"ToString", "/@", 
           RowBox[{"{", "l", "}"}]}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"PrintAs", "[", 
        RowBox[{"v", "[", "]"}], "]"}], "^:=", 
       RowBox[{"ToString", "[", "v", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"SlotsOfTensor", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"{", 
        RowBox[{"TangentBundleOfManifold", "[", "M", "]"}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"SymmetryGroupOfTensor", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"StrongGenSet", "[", 
        RowBox[{
         RowBox[{"{", "}"}], ",", 
         RowBox[{"GenSet", "[", "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"TensorID", "[", 
        RowBox[{"v", "[", "___", "]"}], "]"}], "^:=", 
       RowBox[{"{", "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
